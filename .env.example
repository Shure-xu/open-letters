# Supabase project URL, for example:
# https://dbawvqwmhrgpgcrudnhg.supabase.co
SUPABASE_URL=

# Server-only key used by src/app/api/subscribe/route.ts.
# Never expose this value in client components.
SUPABASE_SERVICE_ROLE_KEY=

# Aliyun Direct Mail SMTP (server-only).
ALIYUN_SMTP_HOST=smtpdm.aliyun.com
ALIYUN_SMTP_PORT=465
ALIYUN_SMTP_SECURE=true
ALIYUN_SMTP_USER=newsletter@mail.xushure.asia
ALIYUN_SMTP_PASSWORD=
NEWSLETTER_FROM_NAME=open letters

# Protects the manual SMTP verification route.
EMAIL_TEST_SECRET=

# Protects the one-off illustrated newsletter preview route.
NEWSLETTER_PREVIEW_SECRET=

# Protects the Vercel Cron request. Vercel sends it as a Bearer token.
CRON_SECRET=

# OpenAI-compatible API used for daily editorial generation and illustrations.
AI_API_BASE_URL=https://ai.mdldm.club/v1
AI_API_KEY=
AI_TEXT_MODEL=gpt-5.4-mini
AI_IMAGE_MODEL=gpt-image-2
AI_IMAGE_QUALITY=medium
